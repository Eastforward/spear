{
  "schema": "avengine_controlled_animal_one_shot_policy_v1",
  "policy_id": "animal_one_shot_no_seed_lottery_v1",
  "purpose": "Make controlled animal base-asset acquisition auditable and fail-closed: one frozen request, one FLUX.2 image, one Pixal3D mesh, no seed sweep and no winner selection.",
  "scope": [
    "flux2_pixal3d_animal_v1"
  ],
  "request_freeze": {
    "authority": "authenticated_instance_request_before_generation",
    "seed_source": "generation_plan.generation_seed",
    "seed_override_after_generation_started_allowed": false,
    "request_replacement_after_observing_output_allowed": false,
    "same_absolute_attributes_may_be_regenerated_to_seek_a_better_seed": false
  },
  "per_request_cardinality": {
    "flux_invocations": 1,
    "flux_images_per_invocation": 1,
    "pixal3d_invocations": 1,
    "accepted_2d_candidates_maximum": 1,
    "accepted_3d_candidates_maximum": 1,
    "seed_retry_allowed": false,
    "candidate_ranking_or_best_of_n_allowed": false,
    "backend_fallback_within_the_same_request_allowed": false
  },
  "failure_policy": {
    "instance_failure_disposition": "preserve_evidence_and_reject_instance",
    "profile_failure_disposition": "revise_prompt_pose_guide_or_deterministic_stage_then_run_a_new_predeclared_validation_revision",
    "failed_output_may_be_hidden_from_profile_metrics": false,
    "failed_request_may_be_replaced_by_a_new_seed_in_the_same_profile_revision": false
  },
  "profile_qualification": {
    "validation_requests_are_frozen_before_first_inference": true,
    "all_predeclared_requests_count": true,
    "required_pass_fraction": 1.0,
    "winner_only_reporting_allowed": false,
    "qualification_is_invalid_if_any_request_is_omitted_after_results_are_known": true
  },
  "pose_and_prompt_contract": {
    "license_authenticated_pose_guide_required": true,
    "camera_roll_deg": 0,
    "level_ground_and_horizon_required": true,
    "straight_projected_torso_axis_required": true,
    "four_separated_complete_limbs_required_for_quadrupeds": true,
    "single_tail_separated_from_hind_limbs_required_when_applicable": true,
    "non_target_anatomy_and_camera_locked": true,
    "prompt_only_is_not_considered_a_geometry_guarantee": true
  },
  "production_instance_policy": {
    "default_after_base_asset_approval": "frozen_geometry_skeleton_skin_and_actions",
    "appearance_variation": "deterministic_semantic_material_or_texture_transform",
    "size_variation": "deterministic_actor_or_root_scale_from_absolute_attribute",
    "body_build_and_age_variation": "bounded_prevalidated_semantic_deformation_on_the_frozen_rig",
    "rerun_flux_or_pixal_for_each_color_or_size_instance": false,
    "new_geometry_acquisition_required_only_for_a_new_taxon_or_geometry_family": true
  },
  "formal_dataset_registration_authorized": false
}
